# ============================================================
# ERP Bustech — Variáveis de ambiente (copie para .env)
# ============================================================
# NUNCA commite o arquivo .env com credenciais reais.

# ── Banco de dados (Supabase) ────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → Database → Connection string → JDBC
# Use a conexão DIRETA (porta 5432), NÃO o Transaction Pooler (porta 6543)
DATABASE_URL=jdbc:postgresql://db.SEU_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=SUA_SENHA_SUPABASE

# ── JWT ──────────────────────────────────────────────────────
# Deve ter no mínimo 32 caracteres. Gere com: openssl rand -base64 64
JWT_SECRET=TROQUE-POR-UMA-CHAVE-SECRETA-COM-MINIMO-32-CHARS
JWT_EXPIRATION_MS=86400000

# ── Conta Azul (OAuth2) — opcional ──────────────────────────
CONTAAZUL_CLIENT_ID=
CONTAAZUL_CLIENT_SECRET=
CONTAAZUL_REDIRECT_URI=http://localhost:8080/api/integrations/conta-azul/callback
