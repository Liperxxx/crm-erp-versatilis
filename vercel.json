{
  "$schema": "https://openapi.vercel.com/vercel.json",
  "framework": null,
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/assets/:path*",
      "destination": "/frontend/assets/:path*"
    },
    {
      "source": "/empresas/:path*",
      "destination": "/frontend/empresas/:path*"
    },
    {
      "source": "/configuracoes/:path*",
      "destination": "/frontend/configuracoes/:path*"
    },
    {
      "source": "/login.html",
      "destination": "/frontend/login.html"
    },
    {
      "source": "/dashboard.html",
      "destination": "/frontend/dashboard.html"
    },
    {
      "source": "/comparativo.html",
      "destination": "/frontend/comparativo.html"
    },
    {
      "source": "/consolidado.html",
      "destination": "/frontend/consolidado.html"
    },
    {
      "source": "/categorias.html",
      "destination": "/frontend/categorias.html"
    },
    {
      "source": "/centros-de-custo.html",
      "destination": "/frontend/centros-de-custo.html"
    },
    {
      "source": "/conta-azul.html",
      "destination": "/frontend/conta-azul.html"
    },
    {
      "source": "/empresas.html",
      "destination": "/frontend/empresas.html"
    },
    {
      "source": "/financeiro.html",
      "destination": "/frontend/financeiro.html"
    },
    {
      "source": "/usuarios.html",
      "destination": "/frontend/usuarios.html"
    },
    {
      "source": "/configuracoes.html",
      "destination": "/frontend/configuracoes.html"
    },
    {
      "source": "/index.html",
      "destination": "/frontend/index.html"
    }
  ]
}
